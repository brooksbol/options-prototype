# Options Prototype — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# .env.local must NOT be committed to the repository.
#
# The mock provider works without any API key.
# These variables are only needed for real-data provider spikes.

VITE_MASSIVE_API_KEY=your_api_key_here
VITE_TRADIER_API_KEY=your_tradier_sandbox_token_here
VITE_TRADIER_API_ACCOUNT_NUMBER=your_account_number_here
